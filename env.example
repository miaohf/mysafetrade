API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
# KID=your_key_id_here

# Trading settings
EXCHANGE=safetrade
EXCHANGE_BASE_URL=https://safetrade.com
API_BASE_URL=https://safe.trade/api/v2
SYMBOL=PRL/USDT
ALLOWED_SYMBOLS=PRL/USDT
MARKET_DATA_SOURCE=safetrade_public
KLINE_PERIOD=60
CANDLE_LIMIT=60
LOOP_INTERVAL_SECONDS=300
RUN_ONCE=false
LOG_FILE=logs/safetrade.log
LOG_LEVEL=INFO
PAPER_TRADING=true
INITIAL_CASH=99
INITIAL_ASSET_QTY=250
FEE_RATE=0.001
MOCK_START_PRICE=0.54

# Risk settings
MAX_POSITION_PCT=0.5
MAX_ORDER_QUOTE=5
MIN_CASH_RESERVE=40
MIN_TRADE_QUOTE=5
